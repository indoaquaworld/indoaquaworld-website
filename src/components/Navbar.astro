---
import Logo from './Logo.astro';
---

<nav>
  <div class="nav-inner">
    <a href="/" class="nav-brand">
      <Logo size={140} />
    </a>
    <ul class="nav-links">
      <li><a href="/platform">Platform</a></li>
      <li><a href="/dufi">DUFI</a></li>
      <li><a href="/about">About</a></li>
      <li><a href="https://app.indoaquaworld.com" class="nav-cta" target="_blank" rel="noopener">Launch App</a></li>
    </ul>
  </div>
</nav>

<style>
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: linear-gradient(180deg, rgba(13, 27, 42, 0.95) 0%, rgba(13, 27, 42, 0.8) 100%);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0.85rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-brand {
    display: flex;
    align-items: center;
    transition: opacity 0.2s;
  }

  .nav-brand:hover {
    opacity: 0.85;
  }

  .nav-links {
    list-style: none;
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }

  .nav-links a {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    letter-spacing: 0.01em;
    transition: color 0.2s;
    position: relative;
  }

  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--color-accent);
    transition: width 0.3s;
  }

  .nav-links a:hover {
    color: #fff;
    text-decoration: none;
  }

  .nav-links a:hover::after {
    width: 100%;
  }

  .nav-cta {
    background: var(--color-accent) !important;
    color: #fff !important;
    padding: 0.5rem 1.25rem;
    border-radius: 6px;
    font-weight: 700 !important;
    transition: transform 0.2s, box-shadow 0.2s !important;
  }

  .nav-cta::after {
    display: none !important;
  }

  .nav-cta:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 15px rgba(243, 73, 19, 0.4);
  }

  @media (max-width: 640px) {
    .nav-links {
      gap: 1.25rem;
    }

    .nav-links a {
      font-size: 0.8rem;
    }

    .nav-cta {
      padding: 0.4rem 0.9rem;
    }
  }
</style>
