---
import Logo from './Logo.astro';
---

<nav>
  <div class="nav-inner">
    <a href="/" class="nav-brand">
      <Logo size={120} />
    </a>
    <ul class="nav-links">
      <li><a href="#features">Platform</a></li>
      <li><a href="#dufi">DUFI</a></li>
      <li><a href="#about">About</a></li>
      <li><a href="#contact">Contact</a></li>
    </ul>
  </div>
</nav>

<style>
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(23, 43, 77, 0.95);
    backdrop-filter: blur(8px);
  }

  .nav-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0.75rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-brand {
    display: flex;
    align-items: center;
  }

  .nav-links {
    list-style: none;
    display: flex;
    gap: 2rem;
  }

  .nav-links a {
    color: #E4E5E9;
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none;
    transition: color 0.2s;
  }

  .nav-links a:hover {
    color: #fff;
    text-decoration: none;
  }

  @media (max-width: 600px) {
    .nav-links {
      gap: 1rem;
    }

    .nav-links a {
      font-size: 0.8rem;
    }
  }
</style>
