---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Logo from '../components/Logo.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import klangPoster from '../assets/images/klang-2026.jpeg';
import heroFish from '../assets/images/ig/golden-base.jpg';
import venueFish from '../assets/images/ig/venue-setup.jpg';
import klasikFish from '../assets/images/ig/klasik-top10.jpg';
import cencuFish from '../assets/images/ig/cencu-ops.jpg';
import kamfaFish from '../assets/images/ig/indo-kamfa.jpg';
---

<BaseLayout title="Indo Aquaworld — Fish Competition Management Platform">
  <Navbar />

  <!-- Hero -->
  <section class="hero">
    <div class="hero-bg">
      <Image src={heroFish} alt="" width={1600} quality={80} />
    </div>
    <div class="hero-overlay"></div>
    <div class="hero-content animate-in">
      <Logo size={320} />
      <p class="hero-tagline">Platform Manajemen<br/>Kompetisi Ikan Hias</p>
      <p class="hero-sub">
        End-to-end competition management — from fish registration
        and multi-criteria scoring to automated ranking and results.
      </p>
      <div class="hero-actions">
        <a href="https://app.indoaquaworld.com" class="btn btn--primary" target="_blank" rel="noopener">Launch App</a>
        <a href="/platform" class="btn btn--outline">Explore Platform</a>
      </div>
    </div>
    <div class="hero-scroll">
      <span>Scroll</span>
      <div class="scroll-line"></div>
    </div>
  </section>

  <!-- Featured Event -->
  <section class="featured-event">
    <div class="section-inner">
      <p class="section-label">Upcoming Event</p>
      <div class="event-card">
        <div class="event-poster">
          <Image src={klangPoster} alt="12th Klang Flowerhorn Competition 2026 poster" width={520} />
        </div>
        <div class="event-info">
          <span class="event-badge">April 2026</span>
          <h2 class="event-title">12th Klang Flowerhorn Competition 2026</h2>
          <div class="event-meta">
            <div class="meta-row">
              <span class="meta-label">Date</span>
              <span>7 — 12 April 2026</span>
            </div>
            <div class="meta-row">
              <span class="meta-label">Venue</span>
              <span>Akuarium De Tropika</span>
            </div>
            <div class="meta-row">
              <span class="meta-label">Location</span>
              <span>Klang, Selangor, Malaysia</span>
            </div>
            <div class="meta-row">
              <span class="meta-label">Organiser</span>
              <span>Zhong Sia — 019-230 7192</span>
            </div>
          </div>
          <a href="/dufi" class="btn btn--primary" style="margin-top: 1.5rem;">View All Events</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Platform Strip -->
  <section class="platform-strip">
    <div class="strip-bg">
      <Image src={venueFish} alt="" width={1600} quality={70} />
    </div>
    <div class="strip-overlay"></div>
    <div class="strip-content">
      <p class="section-label" style="color: var(--color-accent-gold);">The Platform</p>
      <h2 class="section-title section-title--light">Built for Fish Competitions</h2>
      <div class="strip-grid">
        <div class="strip-card">
          <span class="strip-num">01</span>
          <h3>Event Management</h3>
          <p>Create events, assign venues, manage competition status from draft to completion.</p>
        </div>
        <div class="strip-card">
          <span class="strip-num">02</span>
          <h3>8-Criteria Scoring</h3>
          <p>Head, face, body, pearly, colour, marking, fantail, overall — configurable weights.</p>
        </div>
        <div class="strip-card">
          <span class="strip-num">03</span>
          <h3>Automated Ranking</h3>
          <p>Real-time recalculation with penalty handling. Transparent score breakdowns.</p>
        </div>
        <div class="strip-card">
          <span class="strip-num">04</span>
          <h3>Mobile-Ready</h3>
          <p>Progressive Web App — score fish at the venue, view results anywhere.</p>
        </div>
      </div>
      <a href="/platform" class="btn btn--outline" style="margin-top: 2rem;">Full Platform Details</a>
    </div>
  </section>

  <!-- DUFI Spotlight -->
  <section class="dufi-spotlight">
    <div class="section-inner">
      <div class="dufi-header">
        <div>
          <p class="section-label">Our Client</p>
          <h2 class="section-title">DUFI — Djoak United<br/>Flowerhorn Indonesia</h2>
          <p class="dufi-desc">
            One of the major flowerhorn competition organizations in Indonesia,
            operating at an international scale. Organizers of the Indonesia Louhan
            Championship (ILC).
          </p>
          <a href="/dufi" class="btn btn--primary" style="margin-top: 1.5rem;">Explore DUFI</a>
        </div>
      </div>
      <div class="fish-mosaic">
        <div class="mosaic-item mosaic-lg">
          <Image src={klasikFish} alt="Klasik category flowerhorn — vivid red" width={600} />
          <span class="mosaic-label">Klasik</span>
        </div>
        <div class="mosaic-item">
          <Image src={cencuFish} alt="Cencu category flowerhorn — blue pearl markings" width={400} />
          <span class="mosaic-label">Cencu</span>
        </div>
        <div class="mosaic-item">
          <Image src={kamfaFish} alt="Indo Kamfa flowerhorn — pink and red" width={400} />
          <span class="mosaic-label">Indo Kamfa</span>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  /* Hero */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
  }

  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(13, 27, 42, 0.92) 0%,
      rgba(13, 27, 42, 0.75) 40%,
      rgba(243, 73, 19, 0.15) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 750px;
    padding: 0 2rem;
  }

  .hero-tagline {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 7vw, 4.5rem);
    color: #fff;
    letter-spacing: 0.04em;
    line-height: 1.05;
    margin-top: 2rem;
  }

  .hero-sub {
    font-size: 1.1rem;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.7;
    margin-top: 1.25rem;
    max-width: 520px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    margin-top: 2.5rem;
  }

  .hero-scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    z-index: 2;
  }

  .hero-scroll span {
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.4);
  }

  .scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, var(--color-accent), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 1; }
  }

  /* Featured Event */
  .featured-event {
    background: var(--color-surface);
  }

  .event-card {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 3rem;
    margin-top: 2rem;
    background: var(--color-dark);
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
  }

  .event-poster {
    display: flex;
  }

  .event-poster img {
    display: block;
    height: 100%;
    object-fit: cover;
    max-height: 420px;
  }

  .event-info {
    padding: 2.5rem 2.5rem 2.5rem 0;
    color: #fff;
  }

  .event-badge {
    display: inline-block;
    background: var(--color-accent);
    color: #fff;
    font-family: var(--font-display);
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    padding: 0.3rem 1rem;
    border-radius: 4px;
    margin-bottom: 1rem;
  }

  .event-title {
    font-family: var(--font-display);
    font-size: 2rem;
    letter-spacing: 0.02em;
    line-height: 1.1;
    margin-bottom: 1.5rem;
  }

  .event-meta {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .meta-row {
    display: flex;
    gap: 1rem;
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.75);
  }

  .meta-label {
    color: var(--color-accent);
    font-weight: 700;
    min-width: 90px;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Platform Strip */
  .platform-strip {
    position: relative;
    overflow: hidden;
    padding: 6rem 2rem;
    text-align: center;
  }

  .strip-bg {
    position: absolute;
    inset: 0;
  }

  .strip-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .strip-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(13, 27, 42, 0.93) 0%,
      rgba(23, 43, 77, 0.9) 100%
    );
  }

  .strip-content {
    position: relative;
    z-index: 2;
    max-width: 1200px;
    margin: 0 auto;
  }

  .strip-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    margin-top: 3rem;
    text-align: left;
  }

  .strip-card {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-top: 3px solid var(--color-accent);
    border-radius: 12px;
    padding: 1.75rem;
    transition: transform 0.3s, background 0.3s;
  }

  .strip-card:hover {
    transform: translateY(-4px);
    background: rgba(255, 255, 255, 0.08);
  }

  .strip-num {
    font-family: var(--font-display);
    font-size: 2rem;
    color: var(--color-accent);
    opacity: 0.5;
  }

  .strip-card h3 {
    font-family: var(--font-display);
    font-size: 1.35rem;
    color: #fff;
    letter-spacing: 0.03em;
    margin: 0.5rem 0;
  }

  .strip-card p {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.6;
  }

  /* DUFI Spotlight */
  .dufi-spotlight {
    background: #fff;
  }

  .dufi-header {
    margin-bottom: 3rem;
    max-width: 600px;
  }

  .dufi-desc {
    font-size: 1.1rem;
    color: var(--color-text-light);
    line-height: 1.7;
    margin-top: 1rem;
  }

  .fish-mosaic {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: 1rem;
  }

  .mosaic-item {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
  }

  .mosaic-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s;
  }

  .mosaic-item:hover img {
    transform: scale(1.05);
  }

  .mosaic-lg {
    grid-row: 1 / -1;
  }

  .mosaic-label {
    position: absolute;
    bottom: 1rem;
    left: 1rem;
    font-family: var(--font-display);
    font-size: 1.1rem;
    letter-spacing: 0.1em;
    color: #fff;
    background: rgba(13, 27, 42, 0.7);
    backdrop-filter: blur(4px);
    padding: 0.3rem 0.9rem;
    border-radius: 4px;
    border-left: 3px solid var(--color-accent);
  }

  /* Responsive */
  @media (max-width: 900px) {
    .event-card {
      grid-template-columns: 1fr;
    }

    .event-poster img {
      max-height: 280px;
      width: 100%;
    }

    .event-info {
      padding: 2rem;
    }

    .strip-grid {
      grid-template-columns: 1fr 1fr;
    }

    .fish-mosaic {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
    }

    .mosaic-lg {
      grid-row: auto;
    }
  }

  @media (max-width: 600px) {
    .hero-actions {
      flex-direction: column;
      align-items: center;
    }

    .strip-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
