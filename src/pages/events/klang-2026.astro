---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { Image } from 'astro:assets';
import klangPoster from '../../assets/images/klang-2026.jpeg';
import zhongSia from '../../assets/images/organizers/zhong-xia.jpeg';
import lowNelson from '../../assets/images/organizers/low-nelson.jpeg';
import steveHouse from '../../assets/images/organizers/steve-house.jpeg';
---

<BaseLayout title="12th Klang Flowerhorn Competition 2026 — DUFI">
  <Navbar />

  <section class="event-hero">
    <div class="hero-bg"></div>
    <div class="hero-inner">
      <a href="/dufi" class="back-link">&larr; Back to DUFI</a>
      <p class="section-label" style="color: var(--color-accent-gold);">Upcoming Event</p>
      <h1>12th Klang Flowerhorn Competition 2026</h1>
      <p class="hero-sub">
        Organized by Akuarium De Tropikal in Klang, Selangor — the 12th edition
        of one of Malaysia's longest-running flowerhorn competitions, held since 2016.
      </p>
    </div>
  </section>

  <section class="poster-section">
    <div class="section-inner">
      <div class="poster-wrap">
        <Image src={klangPoster} alt="12th Klang Flowerhorn Competition 2026 official poster" width={900} quality={90} />
      </div>
    </div>
  </section>

  <section class="schedule-section">
    <div class="section-inner">
      <p class="section-label">Schedule</p>
      <h2 class="section-title">Event Days</h2>
      <div class="schedule-grid">
        <div class="schedule-card">
          <span class="day-num">07</span>
          <span class="day-label">April 2026</span>
          <h3>Bench-in</h3>
          <p>Drop-off and registration of fish entries at the venue.</p>
        </div>
        <div class="schedule-card highlight">
          <span class="day-num">09</span>
          <span class="day-label">April 2026</span>
          <h3>Judging</h3>
          <p>Multi-criteria scoring across all flowerhorn categories.</p>
        </div>
        <div class="schedule-card">
          <span class="day-num">10—11</span>
          <span class="day-label">April 2026</span>
          <h3>Public Viewing</h3>
          <p>Open to the public to view all competing flowerhorn entries.</p>
        </div>
        <div class="schedule-card">
          <span class="day-num">12</span>
          <span class="day-label">April 2026</span>
          <h3>Prize Presentation</h3>
          <p>Award ceremony for winners across all categories.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="venue-info">
    <div class="section-inner">
      <p class="section-label">Venue</p>
      <h2 class="section-title">Akuarium De Tropikal</h2>
      <p class="venue-name-cn">忠水族馆</p>
      <div class="venue-details">
        <div class="venue-text">
          <p>
            Akuarium De Tropikal — also known as 忠水族馆 — is a Klang-based aquarium
            specializing in flowerhorn (louhan), arowana, and tropical fish. It has hosted
            the Klang Flowerhorn Competition series since 2016.
          </p>
          <div class="address-block">
            <span class="addr-label">Address</span>
            <p>No. 11, Jalan Laksamana 6<br/>Off Jalan Sungai Jati<br/>41200 Klang, Selangor<br/>Malaysia</p>
          </div>
        </div>
        <div class="venue-stats">
          <div class="stat">
            <span class="stat-num">12</span>
            <span class="stat-label">Editions</span>
          </div>
          <div class="stat">
            <span class="stat-num">10+</span>
            <span class="stat-label">Years Running</span>
          </div>
          <div class="stat">
            <span class="stat-num">Since</span>
            <span class="stat-label">2016</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="organizers-section">
    <div class="section-inner">
      <p class="section-label">Event Organizers</p>
      <h2 class="section-title section-title--light">The Team</h2>
      <div class="org-grid">
        <div class="org-card">
          <div class="org-photo">
            <Image src={zhongSia} alt="Zhong Sia, Head Event Organizer" width={500} quality={85} />
          </div>
          <div class="org-body">
            <span class="org-role">Head Event Organizer</span>
            <h3>Zhong Sia</h3>
            <p>
              Founder and proprietor of Akuarium De Tropikal in Klang. Has organized
              the Klang Flowerhorn Competition since its first edition in 2016 — making
              him one of the longest-tenured flowerhorn competition organizers in Malaysia.
            </p>
            <div class="org-specialties">
              <span class="specialty">Flowerhorn</span>
              <span class="specialty">Arowana</span>
              <span class="specialty">Tropical Fish</span>
            </div>
            <div class="org-contact">
              <span class="contact-key">Contact</span>
              <a href="tel:+60192307192">+60 19-230 7192</a>
            </div>
          </div>
        </div>

        <div class="org-card">
          <div class="org-photo">
            <Image src={lowNelson} alt="Low Nelson, Assistant Event Organizer" width={500} quality={85} />
          </div>
          <div class="org-body">
            <span class="org-role">Assistant Event Organizer</span>
            <h3>Low Nelson</h3>
            <p>
              Assistant Event Organizer for the 12th Klang Flowerhorn Competition.
              Supports the event team in coordinating registration, judging logistics,
              and public viewing days.
            </p>
          </div>
        </div>

        <div class="org-card">
          <div class="org-photo">
            <Image src={steveHouse} alt="Steve House, Assistant Event Organizer" width={500} quality={85} />
          </div>
          <div class="org-body">
            <span class="org-role">Assistant Event Organizer</span>
            <h3>Steve House</h3>
            <p>
              Assistant Event Organizer for the 12th Klang Flowerhorn Competition.
              Works alongside the team on event coordination and on-site operations.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="history-section">
    <div class="section-inner">
      <p class="section-label">Competition History</p>
      <h2 class="section-title">12 Editions Since 2016</h2>
      <div class="history-timeline">
        <div class="hist-item current">
          <span class="hist-num">12</span>
          <div class="hist-info">
            <h4>Apr 2026</h4>
            <p>12th Klang Flowerhorn Competition</p>
          </div>
        </div>
        <div class="hist-item">
          <span class="hist-num">11</span>
          <div class="hist-info">
            <h4>Nov 2025</h4>
            <p>11th Klang Flowerhorn Competition</p>
          </div>
        </div>
        <div class="hist-item">
          <span class="hist-num">10</span>
          <div class="hist-info">
            <h4>Jun 2025</h4>
            <p>10th Klang Flowerhorn Competition</p>
          </div>
        </div>
        <div class="hist-item">
          <span class="hist-num">9</span>
          <div class="hist-info">
            <h4>Feb 2025</h4>
            <p>9th Klang Flowerhorn Competition</p>
          </div>
        </div>
        <div class="hist-item">
          <span class="hist-num">8</span>
          <div class="hist-info">
            <h4>Nov 2024</h4>
            <p>8th Klang Flowerhorn Competition</p>
          </div>
        </div>
        <div class="hist-item">
          <span class="hist-num">7</span>
          <div class="hist-info">
            <h4>May 2024</h4>
            <p>7th Klang Flowerhorn Competition</p>
          </div>
        </div>
        <div class="hist-item">
          <span class="hist-num">6</span>
          <div class="hist-info">
            <h4>Dec 2023</h4>
            <p>6th Klang Flowerhorn Competition</p>
          </div>
        </div>
        <div class="hist-item">
          <span class="hist-num">4</span>
          <div class="hist-info">
            <h4>Jul 2018</h4>
            <p>4th Klang Flowerhorn Competition</p>
          </div>
        </div>
        <div class="hist-item">
          <span class="hist-num">3</span>
          <div class="hist-info">
            <h4>Jul 2017</h4>
            <p>3rd Klang Flowerhorn Competition</p>
          </div>
        </div>
        <div class="hist-item">
          <span class="hist-num">2</span>
          <div class="hist-info">
            <h4>Nov 2016</h4>
            <p>2nd Klang Flowerhorn Competition</p>
          </div>
        </div>
        <div class="hist-item">
          <span class="hist-num">1</span>
          <div class="hist-info">
            <h4>Jun 2016</h4>
            <p>1st Klang Flowerhorn Competition</p>
          </div>
        </div>
      </div>
      <p class="history-source">Source: <a href="https://klangflowerhorncentre.com/competitions" target="_blank" rel="noopener">klangflowerhorncentre.com</a></p>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  /* Hero */
  .event-hero {
    position: relative;
    background: var(--color-dark);
    padding: 10rem 2rem 5rem;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 20% 30%, rgba(243,73,19,0.15), transparent 50%),
      radial-gradient(circle at 80% 70%, rgba(212,160,23,0.1), transparent 50%);
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    max-width: 900px;
    margin: 0 auto;
  }

  .back-link {
    display: inline-block;
    color: rgba(255,255,255,0.5);
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .event-hero h1 {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    color: #fff;
    letter-spacing: 0.02em;
    line-height: 1.05;
    margin-top: 0.5rem;
  }

  .hero-sub {
    font-size: 1.15rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.7;
    margin-top: 1.5rem;
    max-width: 720px;
  }

  /* Poster */
  .poster-section {
    background: var(--color-dark);
    padding-bottom: 5rem;
  }

  .poster-section .section-inner {
    padding-top: 0;
  }

  .poster-wrap {
    max-width: 720px;
    margin: 0 auto;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 30px 80px rgba(0,0,0,0.5);
  }

  .poster-wrap img {
    display: block;
    width: 100%;
    height: auto;
  }

  /* Schedule */
  .schedule-section {
    background: var(--color-surface);
  }

  .schedule-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-top: 2.5rem;
  }

  .schedule-card {
    background: #fff;
    border-radius: 12px;
    padding: 1.75rem 1.5rem;
    border-top: 3px solid var(--color-light);
    transition: transform 0.2s, border-color 0.2s;
  }

  .schedule-card:hover {
    transform: translateY(-4px);
    border-top-color: var(--color-accent);
  }

  .schedule-card.highlight {
    border-top-color: var(--color-accent);
    background: linear-gradient(180deg, #fff 0%, rgba(243,73,19,0.04) 100%);
  }

  .day-num {
    display: block;
    font-family: var(--font-display);
    font-size: 3rem;
    color: var(--color-dark);
    line-height: 1;
  }

  .day-label {
    display: block;
    font-size: 0.75rem;
    color: var(--color-text-light);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-top: 0.25rem;
  }

  .schedule-card h3 {
    font-family: var(--font-display);
    font-size: 1.3rem;
    color: var(--color-accent);
    letter-spacing: 0.03em;
    margin: 1rem 0 0.5rem;
  }

  .schedule-card p {
    font-size: 0.85rem;
    color: var(--color-text-light);
    line-height: 1.5;
  }

  /* Venue */
  .venue-info {
    background: #fff;
  }

  .venue-name-cn {
    font-size: 1.5rem;
    color: var(--color-accent);
    margin-top: 0.5rem;
    margin-bottom: 2rem;
  }

  .venue-details {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  .venue-text p {
    font-size: 1rem;
    color: var(--color-text-light);
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .address-block {
    background: var(--color-surface);
    border-left: 3px solid var(--color-accent);
    padding: 1.25rem 1.5rem;
    border-radius: 0 8px 8px 0;
  }

  .addr-label {
    font-family: var(--font-display);
    font-size: 0.85rem;
    color: var(--color-accent);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    display: block;
    margin-bottom: 0.5rem;
  }

  .address-block p {
    font-size: 0.95rem;
    color: var(--color-text);
    line-height: 1.6;
    margin-bottom: 0;
  }

  .venue-stats {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }

  .stat {
    background: var(--color-surface);
    padding: 1.25rem 1.5rem;
    border-radius: 8px;
    border-left: 3px solid var(--color-accent);
    display: flex;
    align-items: baseline;
    justify-content: space-between;
  }

  .stat-num {
    font-family: var(--font-display);
    font-size: 1.75rem;
    color: var(--color-dark);
  }

  .stat-label {
    font-size: 0.85rem;
    color: var(--color-text-light);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Organizers */
  .organizers-section {
    background: var(--color-dark);
  }

  .org-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin-top: 2.5rem;
  }

  .org-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 16px;
    overflow: hidden;
  }

  .org-photo {
    aspect-ratio: 4/3;
    overflow: hidden;
    background: var(--color-dark-mid);
  }

  .org-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  .org-body {
    padding: 2rem;
  }

  .org-role {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 0.8rem;
    color: var(--color-accent);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: rgba(243,73,19,0.1);
    padding: 0.3rem 0.85rem;
    border-radius: 4px;
    margin-bottom: 1rem;
  }

  .org-card h3 {
    font-family: var(--font-display);
    font-size: 2rem;
    color: #fff;
    letter-spacing: 0.02em;
    margin-bottom: 1rem;
  }

  .org-card p {
    font-size: 0.95rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }

  .org-specialties {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .specialty {
    background: rgba(255,255,255,0.06);
    color: rgba(255,255,255,0.75);
    font-size: 0.8rem;
    padding: 0.35rem 0.85rem;
    border-radius: 999px;
    border: 1px solid rgba(255,255,255,0.1);
  }

  .org-contact {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(255,255,255,0.08);
  }

  .contact-key {
    font-family: var(--font-display);
    font-size: 0.8rem;
    color: var(--color-accent);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .org-contact a {
    color: #fff;
    font-weight: 700;
  }

  /* History */
  .history-section {
    background: var(--color-surface);
  }

  .history-timeline {
    margin-top: 2.5rem;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .hist-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: #fff;
    padding: 1rem 1.25rem;
    border-radius: 10px;
    border-left: 3px solid var(--color-light);
  }

  .hist-item.current {
    border-left-color: var(--color-accent);
    background: linear-gradient(135deg, #fff 0%, rgba(243,73,19,0.08) 100%);
  }

  .hist-num {
    font-family: var(--font-display);
    font-size: 2rem;
    color: var(--color-accent);
    line-height: 1;
    min-width: 40px;
  }

  .hist-info h4 {
    font-family: var(--font-display);
    font-size: 0.95rem;
    color: var(--color-dark);
    letter-spacing: 0.05em;
    margin-bottom: 0.15rem;
  }

  .hist-info p {
    font-size: 0.8rem;
    color: var(--color-text-light);
    line-height: 1.4;
  }

  .history-source {
    margin-top: 2rem;
    font-size: 0.8rem;
    color: var(--color-text-light);
  }

  @media (max-width: 900px) {
    .schedule-grid {
      grid-template-columns: 1fr 1fr;
    }

    .venue-details {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .org-grid {
      grid-template-columns: 1fr;
    }

    .history-timeline {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 600px) {
    .schedule-grid {
      grid-template-columns: 1fr;
    }

    .history-timeline {
      grid-template-columns: 1fr;
    }
  }
</style>
