---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import klangPoster from '../assets/images/klang-2026.jpeg';
import ilcPoster from '../assets/images/ig/ilc-registration.webp';
import klasikFish from '../assets/images/ig/klasik-top10.jpg';
import cencuFish from '../assets/images/ig/cencu-ops.jpg';
import kamfaFish from '../assets/images/ig/indo-kamfa.jpg';
import goldenFish from '../assets/images/ig/golden-base.jpg';
import cccFish from '../assets/images/ig/ccc-winner.jpg';
import bonsaiFish from '../assets/images/ig/bonsai-ilc2.jpg';
import strongFish from '../assets/images/ig/flowerhorn-strong.jpg';
import venueImg from '../assets/images/ig/venue-setup.jpg';
---

<BaseLayout title="DUFI — Djoak United Flowerhorn Indonesia">
  <Navbar />

  <!-- Hero -->
  <section class="hero">
    <div class="hero-bg">
      <Image src={strongFish} alt="" width={1600} quality={80} />
    </div>
    <div class="hero-overlay"></div>
    <div class="hero-content animate-in">
      <p class="section-label" style="color: var(--color-accent-gold);">Our Client</p>
      <h1 class="hero-title">DUFI</h1>
      <p class="hero-subtitle">Djoak United Flowerhorn Indonesia</p>
      <p class="hero-desc">
        One of the major flowerhorn (louhan) competition organizations in Indonesia.
        Operating at an international scale — organizers of the Indonesia Louhan Championship (ILC).
      </p>
      <div class="hero-links">
        <a href="https://instagram.com/dufi_official" target="_blank" rel="noopener" class="ig-link">@dufi_official</a>
        <a href="https://instagram.com/dufiofficial.event" target="_blank" rel="noopener" class="ig-link">@dufiofficial.event</a>
      </div>
    </div>
  </section>

  <!-- Upcoming Event -->
  <section class="upcoming">
    <div class="section-inner">
      <p class="section-label">Upcoming Event</p>
      <div class="event-card">
        <div class="event-poster">
          <Image src={klangPoster} alt="12th Klang Flowerhorn Competition 2026" width={480} />
        </div>
        <div class="event-info">
          <span class="event-badge">April 2026</span>
          <h2>12th Klang Flowerhorn Competition 2026</h2>
          <div class="event-meta">
            <div class="meta-item"><span class="meta-key">Date</span> 7 — 12 April 2026</div>
            <div class="meta-item"><span class="meta-key">Venue</span> Akuarium De Tropika</div>
            <div class="meta-item"><span class="meta-key">Location</span> Klang, Selangor, Malaysia</div>
            <div class="meta-item"><span class="meta-key">Organiser</span> Zhong Sia — 019-230 7192</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Event Timeline -->
  <section class="timeline-section">
    <div class="section-inner">
      <p class="section-label">Event History</p>
      <h2 class="section-title">Indonesia Louhan Championship</h2>
      <div class="timeline">
        <div class="tl-item">
          <div class="tl-marker"></div>
          <div class="tl-card">
            <div class="tl-poster">
              <Image src={ilcPoster} alt="ILC 2025-2026 registration poster" width={200} />
            </div>
            <div class="tl-info">
              <span class="tl-date">Mar 2026</span>
              <h3>ILC Final Battle Team 2025—2026</h3>
              <p>Mangga 2 Square, Pademangan, Jakarta Utara</p>
            </div>
          </div>
        </div>
        <div class="tl-item">
          <div class="tl-marker"></div>
          <div class="tl-card">
            <div class="tl-info">
              <span class="tl-date">Jan 2025</span>
              <h3>ILC Final Battle — Java Island Region</h3>
              <p>Surabaya</p>
            </div>
          </div>
        </div>
        <div class="tl-item">
          <div class="tl-marker"></div>
          <div class="tl-card">
            <div class="tl-info">
              <span class="tl-date">Apr 2019</span>
              <h3>Indonesia Louhan Championship #2</h3>
              <p>Raiser, Cibinong, Bogor</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Venue -->
  <section class="venue-section">
    <Image src={venueImg} alt="Competition venue with rows of fish tanks" width={1600} quality={75} />
    <div class="venue-overlay">
      <h2 class="section-title section-title--light">Where Champions Compete</h2>
    </div>
  </section>

  <!-- Fish Gallery -->
  <section class="gallery-section">
    <div class="section-inner">
      <p class="section-label">Gallery</p>
      <h2 class="section-title">Competition Fish</h2>
      <p class="gallery-intro">
        Flowerhorn categories include Cencu, Chinghwa, Golden Base, Free Marking,
        Klasik, Bonsai, and Prospek — each judged across 8 criteria.
      </p>
      <div class="gallery-grid">
        <div class="gallery-item large">
          <Image src={klasikFish} alt="Klasik category flowerhorn" width={700} />
          <span class="gallery-label">Klasik</span>
        </div>
        <div class="gallery-item">
          <Image src={goldenFish} alt="Golden Base flowerhorn" width={500} />
          <span class="gallery-label">Golden Base</span>
        </div>
        <div class="gallery-item">
          <Image src={cencuFish} alt="Cencu category flowerhorn" width={500} />
          <span class="gallery-label">Cencu</span>
        </div>
        <div class="gallery-item">
          <Image src={kamfaFish} alt="Indo Kamfa flowerhorn" width={500} />
          <span class="gallery-label">Indo Kamfa</span>
        </div>
        <div class="gallery-item">
          <Image src={cccFish} alt="CCC 1st winner ILC 2" width={500} />
          <span class="gallery-label">CCC Winner</span>
        </div>
        <div class="gallery-item large">
          <Image src={strongFish} alt="Flowerhorn with pearl markings" width={700} />
          <span class="gallery-label">Free Marking</span>
        </div>
        <div class="gallery-item">
          <Image src={bonsaiFish} alt="Bonsai category flowerhorn" width={500} />
          <span class="gallery-label">Bonsai</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Follow CTA -->
  <section class="follow-cta">
    <div class="section-inner" style="text-align: center;">
      <h2 class="section-title section-title--light">Follow DUFI</h2>
      <p style="color: rgba(255,255,255,0.55); margin-top: 1rem; font-size: 1.1rem;">
        Latest events, results, and fish showcases on Instagram.
      </p>
      <div class="follow-links">
        <a href="https://instagram.com/dufi_official" target="_blank" rel="noopener" class="btn btn--primary">@dufi_official</a>
        <a href="https://instagram.com/dufiofficial.event" target="_blank" rel="noopener" class="btn btn--outline">@dufiofficial.event</a>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  /* Hero */
  .hero {
    position: relative;
    padding: 12rem 2rem 6rem;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
  }

  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(13,27,42,0.92) 0%,
      rgba(13,27,42,0.7) 60%,
      rgba(243,73,19,0.2) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 700px;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(4rem, 12vw, 8rem);
    color: #fff;
    letter-spacing: 0.05em;
    line-height: 0.9;
    margin-top: 0.25rem;
  }

  .hero-subtitle {
    font-family: var(--font-display);
    font-size: 1.3rem;
    color: var(--color-accent);
    letter-spacing: 0.15em;
    margin-top: 0.5rem;
  }

  .hero-desc {
    font-size: 1.1rem;
    color: rgba(255,255,255,0.55);
    line-height: 1.7;
    margin-top: 1.5rem;
    max-width: 520px;
  }

  .hero-links {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
  }

  .ig-link {
    color: rgba(255,255,255,0.7);
    font-weight: 700;
    font-size: 0.95rem;
    padding: 0.5rem 1rem;
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 6px;
    transition: all 0.2s;
  }

  .ig-link:hover {
    color: #fff;
    border-color: var(--color-accent);
    text-decoration: none;
  }

  /* Upcoming */
  .upcoming {
    background: var(--color-surface);
  }

  .event-card {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 2.5rem;
    margin-top: 2rem;
    background: var(--color-dark);
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0,0,0,0.15);
  }

  .event-poster img {
    display: block;
    height: 100%;
    object-fit: cover;
  }

  .event-info {
    padding: 2.5rem 2.5rem 2.5rem 0;
    color: #fff;
  }

  .event-badge {
    display: inline-block;
    background: var(--color-accent);
    font-family: var(--font-display);
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    padding: 0.3rem 1rem;
    border-radius: 4px;
    margin-bottom: 1rem;
  }

  .event-info h2 {
    font-family: var(--font-display);
    font-size: 2rem;
    letter-spacing: 0.02em;
    line-height: 1.1;
    margin-bottom: 1.5rem;
  }

  .event-meta {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .meta-item {
    font-size: 0.95rem;
    color: rgba(255,255,255,0.7);
  }

  .meta-key {
    color: var(--color-accent);
    font-weight: 700;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-right: 0.75rem;
    display: inline-block;
    min-width: 85px;
  }

  /* Timeline */
  .timeline-section {
    background: #fff;
  }

  .timeline {
    margin-top: 3rem;
    border-left: 2px solid var(--color-light);
    padding-left: 2rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .tl-item {
    position: relative;
  }

  .tl-marker {
    position: absolute;
    left: -2.55rem;
    top: 1rem;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--color-accent);
    box-shadow: 0 0 0 4px #fff, 0 0 0 6px var(--color-light);
  }

  .tl-card {
    display: flex;
    gap: 1.5rem;
    background: var(--color-surface);
    border-radius: 12px;
    padding: 1.5rem;
    border-left: 3px solid var(--color-accent);
  }

  .tl-poster img {
    border-radius: 8px;
    max-height: 160px;
    width: auto;
  }

  .tl-date {
    font-family: var(--font-display);
    font-size: 0.85rem;
    color: var(--color-accent);
    letter-spacing: 0.1em;
  }

  .tl-info h3 {
    font-family: var(--font-display);
    font-size: 1.35rem;
    color: var(--color-dark);
    letter-spacing: 0.02em;
    margin: 0.25rem 0 0.5rem;
  }

  .tl-info p {
    font-size: 0.9rem;
    color: var(--color-text-light);
  }

  /* Venue */
  .venue-section {
    position: relative;
    height: 400px;
    overflow: hidden;
  }

  .venue-section > img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .venue-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(0deg, rgba(13,27,42,0.8) 0%, rgba(13,27,42,0.3) 100%);
    display: flex;
    align-items: flex-end;
    padding: 3rem;
  }

  /* Gallery */
  .gallery-section {
    background: var(--color-surface);
  }

  .gallery-intro {
    font-size: 1.05rem;
    color: var(--color-text-light);
    line-height: 1.7;
    max-width: 600px;
    margin-top: 1rem;
    margin-bottom: 2.5rem;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .gallery-item {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    aspect-ratio: 1;
  }

  .gallery-item.large {
    grid-column: span 2;
    aspect-ratio: 2/1;
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s;
  }

  .gallery-item:hover img {
    transform: scale(1.06);
  }

  .gallery-label {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 2.5rem 1rem 1rem;
    background: linear-gradient(0deg, rgba(13,27,42,0.85) 0%, transparent 100%);
    font-family: var(--font-display);
    font-size: 1.1rem;
    letter-spacing: 0.1em;
    color: #fff;
  }

  /* Follow CTA */
  .follow-cta {
    background: var(--color-dark);
  }

  .follow-links {
    display: flex;
    gap: 1rem;
    justify-content: center;
    margin-top: 2rem;
  }

  @media (max-width: 900px) {
    .event-card {
      grid-template-columns: 1fr;
    }

    .event-info {
      padding: 2rem;
    }

    .gallery-grid {
      grid-template-columns: 1fr 1fr;
    }

    .gallery-item.large {
      grid-column: span 2;
    }
  }

  @media (max-width: 600px) {
    .gallery-grid {
      grid-template-columns: 1fr;
    }

    .gallery-item.large {
      grid-column: 1;
      aspect-ratio: 4/3;
    }

    .gallery-item {
      aspect-ratio: 4/3;
    }

    .tl-card {
      flex-direction: column;
    }

    .follow-links {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
