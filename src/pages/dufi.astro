---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import klangPoster from '../assets/images/klang-2026.jpeg';
import ilcPoster from '../assets/images/ig/ilc-registration.webp';
import klasikFish from '../assets/images/ig/klasik-top10.jpg';
import cencuFish from '../assets/images/ig/cencu-ops.jpg';
import kamfaFish from '../assets/images/ig/indo-kamfa.jpg';
import goldenFish from '../assets/images/ig/golden-base.jpg';
import cccFish from '../assets/images/ig/ccc-winner.jpg';
import bonsaiFish from '../assets/images/ig/bonsai-ilc2.jpg';
import strongFish from '../assets/images/ig/flowerhorn-strong.jpg';
import venueImg from '../assets/images/ig/venue-setup.jpg';
---

<BaseLayout title="DUFI — Djoak United Flowerhorn Indonesia">
  <Navbar />

  <!-- Hero -->
  <section class="hero">
    <div class="hero-bg">
      <Image src={strongFish} alt="" width={1600} quality={80} />
    </div>
    <div class="hero-overlay"></div>
    <div class="hero-content animate-in">
      <p class="section-label" style="color: var(--color-accent-gold);">Our Client</p>
      <h1 class="hero-title">DUFI</h1>
      <p class="hero-subtitle">Djoak United Flowerhorn Indonesia</p>
      <p class="hero-desc">
        One of the major flowerhorn (louhan) competition organizations in Indonesia.
        Operating at an international scale — organizers of the Indonesia Louhan Championship (ILC).
      </p>
      <div class="hero-links">
        <a href="https://instagram.com/dufi_official" target="_blank" rel="noopener" class="ig-link">@dufi_official</a>
        <a href="https://instagram.com/dufiofficial.event" target="_blank" rel="noopener" class="ig-link">@dufiofficial.event</a>
      </div>
    </div>
  </section>

  <!-- Upcoming Event -->
  <section class="upcoming">
    <div class="section-inner">
      <p class="section-label">Upcoming Event</p>
      <div class="event-card">
        <div class="event-poster">
          <Image src={klangPoster} alt="12th Klang Flowerhorn Competition 2026" width={480} />
        </div>
        <div class="event-info">
          <span class="event-badge">April 2026</span>
          <h2>12th Klang Flowerhorn Competition 2026</h2>
          <div class="event-meta">
            <div class="meta-item"><span class="meta-key">Date</span> 7 — 12 April 2026</div>
            <div class="meta-item"><span class="meta-key">Venue</span> Akuarium De Tropika</div>
            <div class="meta-item"><span class="meta-key">Location</span> Klang, Selangor, Malaysia</div>
            <div class="meta-item"><span class="meta-key">Organiser</span> Zhong Sia — 019-230 7192</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Event History -->
  <section class="timeline-section">
    <div class="section-inner">
      <p class="section-label">Event History</p>
      <h2 class="section-title">21 Events Since 2023</h2>
      <p class="timeline-intro">2,247 fish entries across competitions in Indonesia and Malaysia.</p>

      <h3 class="year-heading">2026</h3>
      <div class="event-table">
        <div class="ev-row">
          <span class="ev-date">Jan 22 — 25</span>
          <span class="ev-name">Final ILC Battle Team</span>
          <span class="ev-loc">Mangga 2 Square, Jakarta</span>
          <span class="ev-fish">146 fish</span>
        </div>
      </div>

      <h3 class="year-heading">2025</h3>
      <div class="event-table">
        <div class="ev-row">
          <span class="ev-date">Oct 9 — 14</span>
          <span class="ev-name">ILC 3 Battle Team 2025</span>
          <span class="ev-loc">Mangga 2 Square, Jakarta</span>
          <span class="ev-fish">159 fish</span>
        </div>
        <div class="ev-row">
          <span class="ev-date">Jul 2 — 6</span>
          <span class="ev-name">ILC 2 Battle Team</span>
          <span class="ev-loc">Mangga 2 Square, Jakarta</span>
          <span class="ev-fish">158 fish</span>
        </div>
        <div class="ev-row">
          <span class="ev-date">Apr 30 — May 4</span>
          <span class="ev-name">ILC 1 Battle Team</span>
          <span class="ev-loc">Mangga 2 Square, Jakarta</span>
          <span class="ev-fish">156 fish</span>
        </div>
        <div class="ev-row">
          <span class="ev-date">Jan 16 — 19</span>
          <span class="ev-name">Final Java Island Region #3</span>
          <span class="ev-loc">Sentra Wisata Kuliner Kapas Krampung, Surabaya</span>
          <span class="ev-fish">103 fish</span>
        </div>
      </div>

      <h3 class="year-heading">2024</h3>
      <div class="event-table">
        <div class="ev-row">
          <span class="ev-date">Nov 13 — 16</span>
          <span class="ev-name">Bengkulu Louhan Kontes</span>
          <span class="ev-loc">Hotel Merah Putih, Bengkulu</span>
          <span class="ev-fish">50 fish</span>
        </div>
        <div class="ev-row">
          <span class="ev-date">Oct 30 — Nov 3</span>
          <span class="ev-name">Final ILC #3 2024 "Menembus Batas"</span>
          <span class="ev-loc">Transmart Bintaro, Tangerang Selatan</span>
          <span class="ev-fish">150 fish</span>
        </div>
        <div class="ev-row">
          <span class="ev-date">Sep 26 — 29</span>
          <span class="ev-name">Java Island Region #2</span>
          <span class="ev-loc">Pusat Ikan Hias UKM, Johar Baru</span>
          <span class="ev-fish">97 fish</span>
        </div>
        <div class="ev-row">
          <span class="ev-date">Aug 14 — 18</span>
          <span class="ev-name">ILC 2 "Strength In Unity"</span>
          <span class="ev-loc">Transmart Bintaro, Tangerang Selatan</span>
          <span class="ev-fish">151 fish</span>
        </div>
        <div class="ev-row international">
          <span class="ev-date">Jul 23 — 27</span>
          <span class="ev-name">Ipoh Malaysia Flowerhorn Competition 2024</span>
          <span class="ev-loc">Ipoh, Malaysia</span>
          <span class="ev-fish">132 fish</span>
        </div>
        <div class="ev-row">
          <span class="ev-date">Jul 12 — 14</span>
          <span class="ev-name">Java Island Region #1</span>
          <span class="ev-loc">Pusat Ikan Hias UKM, Johar Baru</span>
          <span class="ev-fish">105 fish</span>
        </div>
        <div class="ev-row">
          <span class="ev-date">May 22</span>
          <span class="ev-name">ILC #1 "Integritas & Sinergi"</span>
          <span class="ev-loc">Transmart Bintaro, Tangerang Selatan</span>
          <span class="ev-fish">133 fish</span>
        </div>
        <div class="ev-row">
          <span class="ev-date">Jan 18 — 21</span>
          <span class="ev-name">Regional Jabodetabek "Final Battle"</span>
          <span class="ev-loc">Pusat Ikan Hias UKM, Johar Baru</span>
          <span class="ev-fish">113 fish</span>
        </div>
        <div class="ev-row">
          <span class="ev-date">Jan 11 — 14</span>
          <span class="ev-name">Mini Contest Plat AG</span>
          <span class="ev-loc">Pujasera Gendis, Kediri</span>
          <span class="ev-fish">65 fish</span>
        </div>
      </div>

      <h3 class="year-heading">2023</h3>
      <div class="event-table">
        <div class="ev-row international">
          <span class="ev-date">Dec 1 — 3</span>
          <span class="ev-name">Ipoh Malaysia Flowerhorn Competition 2023</span>
          <span class="ev-loc">Ipoh, Malaysia</span>
          <span class="ev-fish">112 fish</span>
        </div>
        <div class="ev-row">
          <span class="ev-date">Nov 24 — 26</span>
          <span class="ev-name">Final ILC 3 "Sang Juara"</span>
          <span class="ev-loc">Raiser Ikan Hias, Bogor</span>
          <span class="ev-fish">157 fish</span>
        </div>
        <div class="ev-row">
          <span class="ev-date">Sep 29 — Oct 2</span>
          <span class="ev-name">Regional 2 "Unstoppable"</span>
          <span class="ev-loc">Pusat Ikan Hias UKM, Johar Baru</span>
          <span class="ev-fish">114 fish</span>
        </div>
        <div class="ev-row">
          <span class="ev-date">Aug 18 — 21</span>
          <span class="ev-name">ILC 2 "Spirit Of Patriotism"</span>
          <span class="ev-loc">Raiser Ikan Hias, Bogor</span>
          <span class="ev-fish">146 fish</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Venue -->
  <section class="venue-section">
    <Image src={venueImg} alt="Competition venue with rows of fish tanks" width={1600} quality={75} />
    <div class="venue-overlay">
      <h2 class="section-title section-title--light">Where Champions Compete</h2>
    </div>
  </section>

  <!-- Fish Gallery -->
  <section class="gallery-section">
    <div class="section-inner">
      <p class="section-label">Gallery</p>
      <h2 class="section-title">Competition Fish</h2>
      <p class="gallery-intro">
        Flowerhorn categories include Cencu, Chinghwa, Golden Base, Free Marking,
        Klasik, Bonsai, and Prospek — each judged across 8 criteria.
      </p>
      <div class="gallery-grid">
        <div class="gallery-item large">
          <Image src={klasikFish} alt="Klasik category flowerhorn" width={700} />
          <span class="gallery-label">Klasik</span>
        </div>
        <div class="gallery-item">
          <Image src={goldenFish} alt="Golden Base flowerhorn" width={500} />
          <span class="gallery-label">Golden Base</span>
        </div>
        <div class="gallery-item">
          <Image src={cencuFish} alt="Cencu category flowerhorn" width={500} />
          <span class="gallery-label">Cencu</span>
        </div>
        <div class="gallery-item">
          <Image src={kamfaFish} alt="Indo Kamfa flowerhorn" width={500} />
          <span class="gallery-label">Indo Kamfa</span>
        </div>
        <div class="gallery-item">
          <Image src={cccFish} alt="CCC 1st winner ILC 2" width={500} />
          <span class="gallery-label">CCC Winner</span>
        </div>
        <div class="gallery-item large">
          <Image src={strongFish} alt="Flowerhorn with pearl markings" width={700} />
          <span class="gallery-label">Free Marking</span>
        </div>
        <div class="gallery-item">
          <Image src={bonsaiFish} alt="Bonsai category flowerhorn" width={500} />
          <span class="gallery-label">Bonsai</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Follow CTA -->
  <section class="follow-cta">
    <div class="section-inner" style="text-align: center;">
      <h2 class="section-title section-title--light">Follow DUFI</h2>
      <p style="color: rgba(255,255,255,0.55); margin-top: 1rem; font-size: 1.1rem;">
        Latest events, results, and fish showcases on Instagram.
      </p>
      <div class="follow-links">
        <a href="https://instagram.com/dufi_official" target="_blank" rel="noopener" class="btn btn--primary">@dufi_official</a>
        <a href="https://instagram.com/dufiofficial.event" target="_blank" rel="noopener" class="btn btn--outline">@dufiofficial.event</a>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  /* Hero */
  .hero {
    position: relative;
    padding: 12rem 2rem 6rem;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
  }

  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(13,27,42,0.92) 0%,
      rgba(13,27,42,0.7) 60%,
      rgba(243,73,19,0.2) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 700px;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(4rem, 12vw, 8rem);
    color: #fff;
    letter-spacing: 0.05em;
    line-height: 0.9;
    margin-top: 0.25rem;
  }

  .hero-subtitle {
    font-family: var(--font-display);
    font-size: 1.3rem;
    color: var(--color-accent);
    letter-spacing: 0.15em;
    margin-top: 0.5rem;
  }

  .hero-desc {
    font-size: 1.1rem;
    color: rgba(255,255,255,0.55);
    line-height: 1.7;
    margin-top: 1.5rem;
    max-width: 520px;
  }

  .hero-links {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
  }

  .ig-link {
    color: rgba(255,255,255,0.7);
    font-weight: 700;
    font-size: 0.95rem;
    padding: 0.5rem 1rem;
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 6px;
    transition: all 0.2s;
  }

  .ig-link:hover {
    color: #fff;
    border-color: var(--color-accent);
    text-decoration: none;
  }

  /* Upcoming */
  .upcoming {
    background: var(--color-surface);
  }

  .event-card {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 2.5rem;
    margin-top: 2rem;
    background: var(--color-dark);
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0,0,0,0.15);
  }

  .event-poster img {
    display: block;
    height: 100%;
    object-fit: cover;
  }

  .event-info {
    padding: 2.5rem 2.5rem 2.5rem 0;
    color: #fff;
  }

  .event-badge {
    display: inline-block;
    background: var(--color-accent);
    font-family: var(--font-display);
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    padding: 0.3rem 1rem;
    border-radius: 4px;
    margin-bottom: 1rem;
  }

  .event-info h2 {
    font-family: var(--font-display);
    font-size: 2rem;
    letter-spacing: 0.02em;
    line-height: 1.1;
    margin-bottom: 1.5rem;
  }

  .event-meta {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .meta-item {
    font-size: 0.95rem;
    color: rgba(255,255,255,0.7);
  }

  .meta-key {
    color: var(--color-accent);
    font-weight: 700;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-right: 0.75rem;
    display: inline-block;
    min-width: 85px;
  }

  /* Timeline */
  .timeline-section {
    background: #fff;
  }

  .timeline {
    margin-top: 3rem;
    border-left: 2px solid var(--color-light);
    padding-left: 2rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .tl-item {
    position: relative;
  }

  .tl-marker {
    position: absolute;
    left: -2.55rem;
    top: 1rem;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--color-accent);
    box-shadow: 0 0 0 4px #fff, 0 0 0 6px var(--color-light);
  }

  .timeline-intro {
    font-size: 1.05rem;
    color: var(--color-text-light);
    line-height: 1.7;
    margin-top: 0.75rem;
  }

  .year-heading {
    font-family: var(--font-display);
    font-size: 2rem;
    color: var(--color-accent);
    letter-spacing: 0.05em;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--color-light);
  }

  .event-table {
    display: flex;
    flex-direction: column;
  }

  .ev-row {
    display: grid;
    grid-template-columns: 140px 1fr 1fr 80px;
    gap: 1rem;
    padding: 0.85rem 1rem;
    border-bottom: 1px solid var(--color-light);
    align-items: center;
    font-size: 0.9rem;
    transition: background 0.15s;
  }

  .ev-row:hover {
    background: var(--color-surface);
  }

  .ev-row.international {
    border-left: 3px solid var(--color-accent-gold);
  }

  .ev-date {
    color: var(--color-text-light);
    font-size: 0.85rem;
  }

  .ev-name {
    font-weight: 700;
    color: var(--color-dark);
  }

  .ev-loc {
    color: var(--color-text-light);
    font-size: 0.85rem;
  }

  .ev-fish {
    text-align: right;
    font-family: var(--font-display);
    font-size: 0.95rem;
    color: var(--color-accent);
    letter-spacing: 0.05em;
  }

  /* Venue */
  .venue-section {
    position: relative;
    height: 400px;
    overflow: hidden;
  }

  .venue-section > img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .venue-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(0deg, rgba(13,27,42,0.8) 0%, rgba(13,27,42,0.3) 100%);
    display: flex;
    align-items: flex-end;
    padding: 3rem;
  }

  /* Gallery */
  .gallery-section {
    background: var(--color-surface);
  }

  .gallery-intro {
    font-size: 1.05rem;
    color: var(--color-text-light);
    line-height: 1.7;
    max-width: 600px;
    margin-top: 1rem;
    margin-bottom: 2.5rem;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .gallery-item {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    aspect-ratio: 1;
  }

  .gallery-item.large {
    grid-column: span 2;
    aspect-ratio: 2/1;
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s;
  }

  .gallery-item:hover img {
    transform: scale(1.06);
  }

  .gallery-label {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 2.5rem 1rem 1rem;
    background: linear-gradient(0deg, rgba(13,27,42,0.85) 0%, transparent 100%);
    font-family: var(--font-display);
    font-size: 1.1rem;
    letter-spacing: 0.1em;
    color: #fff;
  }

  /* Follow CTA */
  .follow-cta {
    background: var(--color-dark);
  }

  .follow-links {
    display: flex;
    gap: 1rem;
    justify-content: center;
    margin-top: 2rem;
  }

  @media (max-width: 900px) {
    .event-card {
      grid-template-columns: 1fr;
    }

    .event-info {
      padding: 2rem;
    }

    .ev-row {
      grid-template-columns: 1fr 1fr;
      gap: 0.25rem 1rem;
    }

    .ev-date { grid-column: 1; }
    .ev-fish { grid-column: 2; text-align: left; }
    .ev-name { grid-column: 1 / -1; }
    .ev-loc { grid-column: 1 / -1; }

    .gallery-grid {
      grid-template-columns: 1fr 1fr;
    }

    .gallery-item.large {
      grid-column: span 2;
    }
  }

  @media (max-width: 600px) {
    .gallery-grid {
      grid-template-columns: 1fr;
    }

    .gallery-item.large {
      grid-column: 1;
      aspect-ratio: 4/3;
    }

    .gallery-item {
      aspect-ratio: 4/3;
    }

    .tl-card {
      flex-direction: column;
    }

    .follow-links {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
